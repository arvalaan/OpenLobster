#########################################################################
# Application build stage: Build the Go backend and frontend and produce a static binary.
#########################################################################
FROM dhi.io/golang:1.26-debian13-dev AS backend-build

# Install Node.js and pnpm to run backend build scripts
RUN apt-get update && apt-get install -y nodejs npm && rm -rf /var/lib/apt/lists/* \
    && corepack enable && corepack prepare pnpm@9.1.0 --activate

# Copy project files
COPY . /build
WORKDIR /build

# Download Go module dependencies
RUN cd apps/backend && go mod tidy && go mod download

# Install workspace (needed for pnpm --filter)
RUN pnpm install --ignore-scripts

# Build Go backend as static binary (CGO_ENABLED=0 required for scratch image)
ENV CGO_ENABLED=0
RUN pnpm build

# Generate the folders with proper permissions for the final image without using unix commands, only docker layer commands.
# Create .ollama so the Ollama SDK has a writable path (avoids "Failed to load private key" noise when OLLAMA_AUTH is used)
RUN mkdir -p /app/{bin,config,data,logs,.ollama} && \
    chown -R nonroot:nonroot /app && \
    chmod -R 755 /app

RUN cp /build/dist/openlobsterd /app/bin/openlobsterd

#########################################################################
# Final stage: Create a minimal image with the static binary and necessary assets.
#########################################################################
FROM dhi.io/debian-base:bookworm AS runtime

# Switch to root user to install dependencies and set up environment
USER 0

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    git \
    python3 \
    python3-pip \
    chromium \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Create nonroot user directories (nonroot user already exists in base image)
COPY --chown=nonroot:nonroot --from=backend-build /app /app
WORKDIR /app

# Switch to nonroot user and set the working directory
USER nonroot
WORKDIR /app

# Expose OpenLobster gateway and bridge ports
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1


# Start OpenLobster gateway
CMD ["/app/bin/openlobsterd"]

LABEL maintainer="neirth <7413024+Neirth@users.noreply.github.com>" \
    org.opencontainers.image.title="OpenLobster" \
    org.opencontainers.image.description="OpenLobster is a self-hosted, open-source personal ai autonomous agent platform built with Go and Solid.js, designed to run on your own hardware for maximum privacy and control." \
    org.opencontainers.image.licenses="MIT" \
    org.opencontainers.image.source="https://github.com/neirth/OpenLobster" \
    org.opencontainers.image.created="2026-02-14"