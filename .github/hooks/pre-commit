#!/usr/bin/env sh
# Pre-commit: backend lint + tests, frontend lint + tests.
set -eu

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

step() {
  printf '\n\033[1m== %s ==\033[0m\n' "$1"
}

step "Backend: golangci-lint"
if ! command -v golangci-lint >/dev/null 2>&1; then
  die "golangci-lint not found in PATH. Install: https://golangci-lint.run/welcome/install/"
fi
(cd apps/backend && golangci-lint run ./...)

step "Backend: go test"
(cd apps/backend && bash scripts/run-coverage.sh)

step "Package @openlobster/ui: eslint"
(cd packages/ui && pnpm exec eslint . --max-warnings 0)

step "Package @openlobster/ui: vitest"
(cd packages/ui && pnpm exec vitest run)

step "App @openlobster/frontend: eslint"
(cd apps/frontend && pnpm exec eslint src tests --max-warnings 0)

step "App @openlobster/frontend: vitest"
(cd apps/frontend && pnpm exec vitest run)

printf '\n\033[1mPre-commit OK\033[0m\n'
